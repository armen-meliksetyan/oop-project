<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="CENTER" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.oopproject.ui.CustomerDashboardController">
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Customer Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <VBox spacing="15" alignment="CENTER">
        <Button text="View Menu" onAction="#handleViewMenu" prefWidth="200"/>
        <Button text="Place Order" onAction="#handlePlaceOrder" prefWidth="200"/>
        <Button text="View My Orders" onAction="#handleViewMyOrders" prefWidth="200"/>
        <Button text="Exit" onAction="#handleExit" prefWidth="200" style="-fx-background-color: #ff4444; -fx-text-fill: white;"/>
    </VBox>

    <Label fx:id="welcomeLabel" style="-fx-font-size: 16px;"/>
</VBox>